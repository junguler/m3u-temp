        window.WavelyPlayer = (function () {
            function audio() { return document.getElementById('wavely-audio'); }
            function bar()   { return document.getElementById('wavely-player'); }
            function $(id)   { return document.getElementById(id); }

            function setPlayingUI(playing) {
                var b = bar(); if (!b) return;
                b.classList.toggle('is-playing', playing);
            }

            // Reflect playback state on every on-page trigger (station cards, the
            // station-page Play button, stream rows) so the one matching the active
            // station shows a pause glyph while playing / a spinner while buffering.
            function syncTriggers() {
                var a = audio();
                var activeId = a ? a.dataset.stationId : null;
                var loading = activeId && $('wp-spinner') && !$('wp-spinner').classList.contains('hidden');
                var playing = activeId && a && !a.paused;
                document.querySelectorAll('[data-station-play]').forEach(function (b) {
                    var active = activeId && b.dataset.id === activeId;
                    b.classList.toggle('is-loading', !!(active && loading));
                    b.classList.toggle('is-playing', !!(active && playing && !loading));
                });
            }

            function ensureWired() {
                var a = audio();
                if (!a || a.dataset.wired) return;
                a.dataset.wired = '1';
                a.addEventListener('playing', function () { setPlayingUI(true); $('wp-spinner').classList.add('hidden'); syncTriggers(); });
                a.addEventListener('pause',  function () { setPlayingUI(false); syncTriggers(); });
                a.addEventListener('waiting', function () { $('wp-spinner').classList.remove('hidden'); syncTriggers(); });
                a.addEventListener('error',  function () { $('wp-spinner').classList.add('hidden'); setPlayingUI(false); syncTriggers(); });
                var vol = $('wp-volume');
                if (vol) vol.addEventListener('input', function () { a.volume = parseFloat(vol.value); });
            }

            function play(data) {
                ensureWired();
                var a = audio(); if (!a || !data.url) return;

                // Tapping the current station toggles pause/play.
                if (a.dataset.stationId === data.id) {
                    if (a.paused) { a.play().catch(function () {}); } else { a.pause(); }
                    return;
                }

                a.dataset.stationId = data.id;
                a.src = data.url;
                $('wp-spinner').classList.remove('hidden');
                syncTriggers();
                a.play().catch(function () { $('wp-spinner').classList.add('hidden'); syncTriggers(); });

                $('wp-name').textContent = data.name || '';
                $('wp-sub').textContent  = data.sub || '';

                var art = $('wp-art');
                if (data.logo) {
                    art.style.backgroundImage = 'url(' + data.logo + ')';
                    art.textContent = '';
                } else {
                    art.style.backgroundImage = '';
                    art.textContent = (data.name || '?').trim().charAt(0).toUpperCase();
