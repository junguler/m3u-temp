                bar().classList.remove('hidden');

                if ('mediaSession' in navigator) {
                    navigator.mediaSession.metadata = new MediaMetadata({
                        title: data.name || 'Wavely',
                        artist: data.sub || '',
                        artwork: data.logo ? [{ src: data.logo, sizes: '512x512' }] : [],
